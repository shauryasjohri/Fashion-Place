# PostgreSQL connection string (Neon or local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fashion-place

# JWT secret key (use a strong random string)
JWT_SECRET=your_jwt_secret_here

# Razorpay key id and secret (from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Server port (defaults to 5000 if not set)
PORT=5000

# Clerk secret key (from https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
